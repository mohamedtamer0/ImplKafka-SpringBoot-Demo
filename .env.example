# Values used by the Spring Boot application when it runs on the host.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SERVER_PORT=8081
KAFKA_TEXT_TOPIC=kafkalearn
KAFKA_USER_TOPIC=kafkalearn_json
KAFKA_CONSUMER_GROUP=myGroup
KAFKA_CONSUMER_CONCURRENCY=1
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_DEAD_LETTER_SUFFIX=.dlt
KAFKA_RETRY_MAX_ATTEMPTS=3
KAFKA_RETRY_BACKOFF=1s
KAFKA_SEND_TIMEOUT=12s
